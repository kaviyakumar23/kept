# --- LLM (provider-agnostic; default = Anthropic Claude) ---
ANTHROPIC_API_KEY=
KEPT_LLM_MODEL=claude-opus-4-8

# --- Event store (Postgres) ---
DATABASE_URL=postgres://kept:kept@localhost:5432/kept

# --- Reminder / retry queue (Redis + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Slack (hybrid substrate: real Slack surface) ---
# Two boot modes (auto-selected):
#  1. Single-token / Socket Mode (local dev, demo): set SLACK_BOT_TOKEN (+ optional
#     SLACK_APP_TOKEN for Socket Mode). Leave the OAuth trio below EMPTY.
#  2. OAuth HTTP mode (W2, multi-workspace, the Marketplace/AWS deploy): set
#     SLACK_CLIENT_ID + SLACK_CLIENT_SECRET + SLACK_STATE_SECRET. No bot token needed;
#     each workspace's token is stored in the InstallationStore at install time.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Slack OAuth (W2 HTTP mode; all three enable OAuth HTTP mode) ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Any long random string — signs the OAuth `state` param (e.g. `openssl rand -hex 32`).
SLACK_STATE_SECRET=
# Public HTTPS origin the app is reachable at (for the manifest request/redirect URLs).
KEPT_PUBLIC_URL=

# --- Server port (App Runner sets this; local default 3000) ---
PORT=3000

# --- Roadmap source for the contradiction check (else Postgres `roadmap` table if DATABASE_URL set) ---
KEPT_ROADMAP_FILE=./roadmap.example.json

# --- Cross-channel RTS via Slack user-token search (set to 1 to enable; needs user-token OAuth) ---
KEPT_SLACK_USER_SEARCH=

# --- Work items via MCP (preferred; satisfies the "MCP server integration" requirement) ---
# Default with NO config below: an in-process SIMULATED MCP server — a real MCP
# client↔server round-trip, no network/OAuth. Precedence: Linear MCP > Atlassian
# MCP > legacy direct-API adapters > simulated MCP.
#
# Linear hosted MCP server (https://mcp.linear.app/mcp) — set a Bearer token to use it:
LINEAR_MCP_TOKEN=
LINEAR_MCP_URL=
LINEAR_TEAM_ID=
# Atlassian/Jira hosted Remote MCP server (https://mcp.atlassian.com/v1/mcp):
ATLASSIAN_MCP_TOKEN=
ATLASSIAN_MCP_URL=
JIRA_CLOUD_ID=
JIRA_PROJECT_KEY=
# Override the create-issue tool name if the server's differs from auto-detection:
KEPT_MCP_TOOL=

# --- Legacy direct-API work-item adapters (used only if no MCP token is set above) ---
LINEAR_API_KEY=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Webhook ingestion guard + tenant routing ---
KEPT_WEBHOOK_SECRET=
# Default tenant for webhooks that don't carry an `x-kept-team` header (single-tenant
# dev / the demo driver). In OAuth mode, webhooks with no header/default are routed to
# whichever installed workspace's ledger resolves their refs.
KEPT_TEAM_ID=
# Standalone webhook server port (single-token / Socket Mode dev only; in OAuth HTTP
# mode webhooks are served on PORT alongside /slack/events).
KEPT_WEBHOOK_PORT=3001
